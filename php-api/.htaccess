# Route every /webshop/mrszoko/api/* request that isn't a real file to the
# router (index.php), which dispatches /franchisor/* endpoints. Apache + mod_rewrite.
# Requires the vhost/dir to allow overrides (AllowOverride FileInfo, or All).
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /webshop/mrszoko/api/
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.php [QSA,L]
</IfModule>

# Fallback for servers without mod_rewrite (Apache 2.2.16+).
<IfModule !mod_rewrite.c>
  FallbackResource /webshop/mrszoko/api/index.php
</IfModule>

# Only index.php may be reached over HTTP. Every other PHP file (migrate.php,
# seed.php, db.php, delivery.php, config*.php) is include-only — deny direct
# web access so nobody can trigger a migrate/seed or read config over the web.
# (Denying HTTP access does NOT stop index.php from include()'ing them.)
<FilesMatch "\.php$">
  Require all denied
</FilesMatch>
<Files "index.php">
  Require all granted
</Files>

# Don't expose the SQLite DB or its journal to the web.
<FilesMatch "\.(sqlite|sqlite-journal)$">
  Require all denied
</FilesMatch>

# Belt-and-suspenders: no listing/serving of the data, tests or schema dirs.
RedirectMatch 404 /webshop/mrszoko/api/(data|tests|schema)/
