  },
  "defaultScreen": "dash",
  "nav": [
    { "label": "Pilotage", "collapsible": false, "items": [
      { "screen": "dash", "label": "Tableau de bord réseau", "dot": "copper" },
      { "screen": "boutiques", "label": "Boutiques", "dot": "apricot" },
      { "screen": "audit", "label": "Journal d'audit", "dot": "muted" },
      { "screen": "catalogue", "label": "Catalogue", "dot": "primary" },
      { "screen": "promos", "label": "Promotions réseau", "dot": "apricot" }
    ]},
    { "label": "Paramétrage", "collapsible": true, "open": false, "items": [
      { "screen": "config", "label": "Config marque", "dot": "primary" },
      { "screen": "comms", "label": "Communications", "dot": "primary" },
      { "screen": "users", "label": "Utilisateurs & rôles", "dot": "copper" }
    ]}
  ],
  "screens": {
    "dash": {
      "title": "Tableau de bord réseau", "sub": "Consolidé multi-boutiques · L'Atelier By",
      "kind": "dashboard", "kpis": "kpis",
      "table": {
        "title": "Boutiques du réseau",
        "note": "Vue consolidée · CA du mois · adoption de la whitelist marque",
        "dataset": "shops",
        "columns": [
          { "w": "1.7fr", "header": "Boutique", "type": "text", "field": "nom" },
          { "w": ".9fr", "header": "Ville", "type": "muted", "field": "ville" },
          { "w": ".8fr", "header": "Webshop", "align": "center", "type": "statePill", "flag": "shopWeb_{id}", "def": "web",
            "on": { "text": "En ligne", "bg": "successBg", "fg": "success" },
            "off": { "text": "Coupé", "bg": "bgSec", "fg": "muted" } },
          { "w": ".9fr", "header": "CA boutique", "align": "right", "type": "euro", "field": "caShop", "color": "primary", "dashIfZero": true },
          { "w": ".9fr", "header": "CA bureau", "align": "right", "type": "euro", "field": "caOffice", "color": "office", "dashIfZero": true },
          { "w": ".8fr", "header": "Adoption", "align": "right", "type": "thresholdText", "field": "adoption", "suffix": " %",
            "thresholds": [ { "min": 85, "color": "success" }, { "min": 70, "color": "warn" } ], "else": "primary" }
        ]
      }
    },
    "boutiques": {
      "title": "Boutiques", "sub": "Identité · branding · webshop",
      "kind": "table", "badge": "ws_shops ← franchise_shops · synchronisé", "dataset": "shops",
      "columns": [
        { "w": "1.6fr", "header": "Boutique", "type": "nameAccent", "field": "nom", "accent": "accent" },
        { "w": "1fr", "header": "Ville", "type": "muted", "field": "ville" },
        { "w": ".8fr", "header": "Webshop", "align": "center", "type": "toggle", "flag": "shopWeb_{id}", "def": "web" },
        { "w": ".9fr", "header": "Contrat", "type": "muted", "field": "contrat" },
        { "w": ".7fr", "header": "Actif", "align": "center", "type": "toggle", "flag": "shopAct_{id}", "def": "act" },
        { "w": "40px", "header": "", "type": "edit", "form": "shop", "map": { "nom": "nom", "ville": "ville", "contrat": "contrat" }, "strip": ["ville"] }
      ]
    },
    "audit": {
      "title": "Journal d'audit", "sub": "Traçabilité des actions sensibles",
      "kind": "table", "cardTitle": "Journal d'audit", "badge": "bo_audit",
      "note": "Toute écriture sensible est tracée · horodatage, acteur, action, entité, boutique",
      "dataset": "audit",
      "columns": [
        { "w": "1fr", "header": "Horodatage", "type": "monoMuted", "field": "ts" },
        { "w": "1.3fr", "header": "Acteur", "type": "text", "field": "user" },
        { "w": "1.6fr", "header": "Action", "type": "pillText", "field": "verb", "text": "entity",
          "map": { "Création": { "bg": "successBg", "fg": "success" }, "Suppression": { "bg": "dangerBg", "fg": "primary" }, "Modification": { "bg": "warnBg", "fg": "warn" } } },
        { "w": "1.1fr", "header": "Boutique", "type": "muted", "field": "shop" }
      ]
    },
    "catalogue": {
      "title": "Catalogue", "sub": "Produits · catégories · i18n",
      "kind": "catalogue",
      "badge": "ws_products · product_categories · ws_season ← ERP (lecture)",
      "badgeAside": "Prix réf. & gouvernance éditables · catalogue synchronisé ERP",
      "note": "<strong>Prix réf.</strong> conseillé réseau · <strong>Webshop marque</strong> = whitelist ⇩ · <strong>Obligatoire</strong> verrouille l'assortiment franchisé · adoption = % boutiques",
      "dataset": "catalog",
      "statusMap": { "Publié": { "bg": "successBg", "fg": "success" }, "Brouillon": { "bg": "bgSec", "fg": "muted" }, "Saisonnier": { "bg": "warnBg", "fg": "warn" } },
      "seasonPill": { "bg": "warnBg", "fg": "office" },
      "columns": [
        { "w": "2.2fr", "header": "Catégorie / produit" },
        { "w": ".9fr", "header": "Prix réf.", "align": "right" },
        { "w": ".9fr", "header": "Webshop", "align": "center" },
        { "w": ".9fr", "header": "Oblig.", "align": "center" },
        { "w": "1.1fr", "header": "Adoption" },
        { "w": "40px", "header": "" }
      ],
      "adThresholds": [ { "min": 80, "color": "success" }, { "min": 50, "color": "warn" } ], "adElse": "primary"
    },
    "promos": {
      "title": "Promotions réseau", "sub": "Bons & règles à portée réseau", "kind": "promos",
      "vouchers": {
        "title": "Bons marque", "note": "ws_vouchers · shop_id NULL = tout le réseau ⇩",
        "add": { "label": "+ Bon marque", "form": "voucher", "variant": "primary" },
        "dataset": "vouchers", "scopeBadge": "Réseau"
      },
      "pricing": {
        "title": "Règles de prix réseau", "note": "ws_pricing_rules · shop_id NULL",
        "add": { "label": "+ Règle", "form": "pricing", "variant": "secondary" },
        "dataset": "pricing",
        "columns": [
          { "w": "1.8fr", "header": "Règle", "type": "text", "field": "nom" },
          { "w": "1.1fr", "header": "Cible", "type": "muted", "field": "cible" },
          { "w": ".9fr", "header": "Effet", "align": "right", "type": "textStrong", "field": "effet" }
        ]
      }
    },
    "config": {
      "title": "Config marque", "sub": "Paramètres généraux (liste blanche)",
      "kind": "params", "cardTitle": "Config marque", "badge": "ws_param (liste blanche)",
      "note": "Seuls les paramètres autorisés sont éditables · flags, icônes nav, URLs, deadlines",
      "dataset": "params"
    },
    "comms": {
      "title": "Communications", "sub": "Modèles d'email transactionnels",
      "kind": "table", "badge": "ws_email_templates (clé × langue × marque)",
      "add": { "label": "+ Modèle", "form": "template", "variant": "primary" },
      "dataset": "templates",
      "columns": [
        { "w": "1.4fr", "header": "Modèle", "type": "mono", "field": "cle" },
        { "w": "2fr", "header": "Sujet", "type": "muted", "field": "sujet" },
        { "w": ".7fr", "header": "Langue", "align": "center", "type": "pill", "field": "langue", "style": { "bg": "bgSec", "fg": "muted" } },
        { "w": "40px", "header": "", "type": "edit", "form": "template", "map": { "cle": "cle", "langue": "langue", "sujet": "sujet" } }
      ],
      "footer": "Variables disponibles : <span style=\"font-family:var(--font-mono);color:var(--color-text)\">{{client_nom}} · {{commande_ref}} · {{montant}} · {{date_livraison}} · {{bureau}}</span>"
    },
    "users": {
      "title": "Utilisateurs & rôles", "sub": "Comptes back-office & portée (RBAC)",
      "kind": "table", "badge": "bo_users · bo_user_shops (RBAC)",
      "add": { "label": "+ Utilisateur", "form": "user", "variant": "primary" },
      "dataset": "users",
      "columns": [
        { "w": "1.4fr", "header": "Nom", "type": "text", "field": "nom" },
        { "w": "1.6fr", "header": "Email", "type": "mutedSm", "field": "email" },
        { "w": ".9fr", "header": "Rôle", "type": "pill", "field": "role",
          "map": { "Siège": { "bg": "dangerBg", "fg": "primary" }, "Franchise": { "bg": "bgSec", "fg": "muted" } } },
        { "w": "1.3fr", "header": "Portée", "type": "mutedSm", "field": "portee" },
        { "w": ".7fr", "header": "Actif", "align": "center", "type": "toggle", "flag": "userAct_{i}", "def": "act" },
        { "w": "40px", "header": "", "type": "edit", "form": "user", "map": { "nom": "nom", "email": "email", "role": "role", "portee": "portee" } }
      ]
    }
  },
