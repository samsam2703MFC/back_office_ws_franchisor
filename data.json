    "primary": "var(--color-primary)",
    "text": "var(--color-text)",
    "muted": "var(--color-text-muted)",
    "surface": "var(--color-surface)",
    "bgSec": "var(--color-background-secondary)",
    "borderSec": "var(--color-border-secondary)",
    "borderTer": "var(--color-border-tertiary)",
    "success": "#2d7a3e",
    "warn": "#b26a00",
    "office": "#C87A3F",
    "apricot": "#E8A15C",
    "copper": "#8C4A2F",
    "info": "#2a5a9e",
    "successBg": "#eaf5ec",
    "warnBg": "#fbf1e3",
    "dangerBg": "#fbe9eb",
    "infoBg": "#eef3fb"
  },
